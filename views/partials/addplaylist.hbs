<form class="ui stacked segment form" action="/dashboard/addplaylist" method="POST">
    <div class="field">
        <label>Title</label>
        <input placeholder="Add your title here!" type="text" name="title" autofocus required>
    </div>
    <div class="field">
        <label>Rating</label>
        <input placeholder="Add your rating here!" type="number" name="range" min="1" max="5" autofocus required>
    </div>
    <button class="ui blue submit button">Add Playlist</button>
</form>